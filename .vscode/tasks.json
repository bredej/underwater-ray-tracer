{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B",
                "${workspaceFolder}/build",
                "-DBUILD_TESTING=ON",
                "-DBUILD_EXAMPLES=ON"
            ],
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "Build Tests",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--target",
                "urt-test",
                "--parallel"
            ],
            "group": {
                "kind": "build"
            },
            "dependsOn": [
                "Configure"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Build Examples",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--target",
                "plot",
                "--parallel"
            ],
            "group": {
                "kind": "build"
            },
            "dependsOn": [
                "Configure"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Build All",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--parallel"
            ],
            "group": {
                "kind": "build"
            },
            "dependsOn": [
                "Configure"
            ]
        },
        {
            "label": "Clean build",
            "type": "shell",
            "command": "rm",
            "args": [
                "-rf",
                "${workspaceFolder}/build"
            ]
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "${workspaceFolder}/build/test/urt-test",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "focus": true,
                "clear": true
            },
            "dependsOn": [
                "Build Tests"
            ]
        }
    ]
}
